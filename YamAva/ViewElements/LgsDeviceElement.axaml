<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:YamAva.ViewModels"
             xmlns:conv="using:YamAva.ViewLogic"
             xmlns:local="using:YamAva.ViewElements"
             mc:Ignorable="d"
             x:Class="YamAva.ViewElements.LgsDeviceElement"
             x:Name="me">

    <StackPanel Margin="12,0,0,8">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding LogitechDevice.DeviceName, ElementName=me, Converter={conv:LogitechNameConverter}}" d:Text="GXXX" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#EEEEEE" MaxWidth="36" Margin="0,0,8,0" Padding="0">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-90"/>
                </TextBlock.RenderTransform>
            </TextBlock>

            <Grid>
                <Image Source="{Binding DeviceType, ElementName=me}" MaxHeight="36" />
                <Image Source="/Resources/Battery_dark.png" MaxHeight="36" />
                <Image Source="{Binding BatteryIndicator, ElementName=me}" MaxHeight="36" />
                <Image Source="/Resources/Charging.png" MaxHeight="36" IsVisible="{Binding IsCharging, ElementName=me}" />
            </Grid>
            <TextBlock Text="{Binding LogitechDevice.BatteryPercentage, ElementName=me, StringFormat={}{0} %}" FontSize="14" Margin="8,0,0,0" Foreground="WhiteSmoke" d:Text="65 %" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </StackPanel>
    </StackPanel>
</UserControl>
