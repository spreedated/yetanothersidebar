<Window x:Class="YetAnotherMonitor.Views.Conversions"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" d:DataContext="{d:DesignInstance vm:ConversionsViewModel}"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:YetAnotherMonitor.ViewModels"
        xmlns:local="clr-namespace:YetAnotherMonitor.Views"
        xmlns:toolkit="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Conversions"
        Height="250"
        MaxHeight="800"
        Width="800"
        MouseDown="Window_MouseDown"
        Style="{StaticResource WindowStyle}"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:ConversionsViewModel/>
    </Window.DataContext>

    <Border Style="{StaticResource WindowBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl Margin="12">
                <TabControl.Style>
                    <Style TargetType="TabControl">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </TabControl.Style>

                <TabItem Header="ASCII">
                    <Frame Content="{Binding AsciiPage}" Margin="5"/>
                </TabItem>

                <TabItem Header="Unicode">
                    <Frame Content="{Binding UnicodePage}" Margin="5"/>
                </TabItem>

                <TabItem Header="Url Encode">
                    <Frame Content="{Binding UrlEncodePage}" Margin="5"/>
                </TabItem>

                <TabItem Header="Base64">
                    <Frame Content="{Binding Base64Page}" Margin="5"/>
                </TabItem>
            </TabControl>

            <Button Grid.Row="1" Content="Exit" Width="120" Height="32" Style="{StaticResource DefaultButton}" Margin="4,4,12,4" HorizontalAlignment="Right" Command="{Binding ExitCommand}" />
        </Grid>
    </Border>
</Window>
