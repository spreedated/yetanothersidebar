                        <Label Margin="-20,5,0,0" HorizontalAlignment="Center" Content="{Binding NzbResponse.Date}" d:Content="1.7.1987 12:55:55" ContentStringFormat="{}{0:dd.MM.yy HH\:mm}" FontWeight="Bold" FontSize="9" Foreground="Gray" />

                        <Canvas Margin="0,0,0,4" />
                    </StackPanel>
