            <!-- # ### # -->

            <!-- FPV Stuff -->
            <StackPanel Orientation="Vertical" Grid.Row="8" Margin="0,10,0,12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border CornerRadius="10" BorderThickness="2" BorderBrush="#444444">
                    <StackPanel Orientation="Vertical" Margin="0">
                        <Label Content="FPV Firmwares" FontSize="9" Margin="8,0,0,0"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,-8">
                            <Label Content="BlueJay:"/>
                            <Label Content="{Binding FpvResponse.BlueJay}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,-8">
                            <Label Content="Betaflight FW:"/>
                            <Label Content="{Binding FpvResponse.BetaflightFw}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,-8">
                            <Label Content="Betaflight CFG:"/>
                            <Label Content="{Binding FpvResponse.BetaflightConf}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,-8">
                            <Label Content="ExpressLRS:"/>
                            <Label Content="{Binding FpvResponse.ExpressLRS}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Label Content="EdgeTX:"/>
                            <Label Content="{Binding FpvResponse.EdgeTX}" FontWeight="Bold"/>
                        </StackPanel>

                        <Canvas Margin="0,0,0,4" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <!-- # ### # -->

            <!-- Logitech Devices -->
            <StackPanel Orientation="Vertical" Grid.Row="9" Margin="0,10,0,12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border CornerRadius="10" BorderThickness="2" BorderBrush="#444444">
                    <StackPanel Orientation="Vertical" Margin="0">
                        <Label Content="Logitech Wireless Devices" FontSize="9" Margin="8,0,0,0"/>
                        <Canvas Margin="0,0,0,10" />

                        <StackPanel x:Name="LgsStackPanel" Orientation="Vertical">
                            <!-- Filled by Code -->
                        </StackPanel>

                        <Canvas Margin="0,0,0,4" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <!-- # ### # -->
        </Grid>
    </Border>
</Window>
