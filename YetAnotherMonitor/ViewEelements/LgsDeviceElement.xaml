<UserControl x:Class="YetAnotherMonitor.ViewEelements.LgsDeviceElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:YetAnotherMonitor.ViewEelements"
             xmlns:conv="clr-namespace:YetAnotherMonitor.ViewLogic.Converters"
             mc:Ignorable="d" 
             x:Name="me">

    <StackPanel Margin="12,0,0,8">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding LogitechDevice.DeviceName, ElementName=me, Converter={conv:LogitechNameConverter}}" d:Text="GXXX" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#EEEEEE" MaxWidth="36" Margin="0,0,8,0" Padding="0">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="-90"/>
                </TextBlock.LayoutTransform>
            </TextBlock>
            <Grid>
                <Image d:Source="/Resources/Keyboard_dark.png" Source="{Binding DeviceType, ElementName=me}" MaxHeight="36" />
                <Image Source="/Resources/Battery_dark.png" MaxHeight="36" />
                <Image d:Source="/Resources/Indicator_50.png" Source="{Binding BatteryIndicator, ElementName=me}" MaxHeight="36" />
                <Image Source="/Resources/Charging.png" MaxHeight="36" Visibility="{Binding IsCharging, ElementName=me}" />
            </Grid>
            <TextBlock Text="{Binding LogitechDevice.BatteryPercentage, ElementName=me, StringFormat={}{0} %}" FontSize="14" Margin="8,0,0,0" Foreground="WhiteSmoke" d:Text="65 %" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </StackPanel>
    </StackPanel>
</UserControl>
