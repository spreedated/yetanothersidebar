<UserControl x:Class="YetAnotherMonitor.ViewEelements.LgsDeviceElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:YetAnotherMonitor.ViewEelements"
             xmlns:conv="clr-namespace:YetAnotherMonitor.ViewLogic.Converters"
             mc:Ignorable="d" 
             x:Name="me"
             d:DesignHeight="48" d:DesignWidth="120">

    <StackPanel Margin="12,0,0,8">
        <TextBlock Text="{Binding LogitechDevice.DeviceName, ElementName=me}" d:Text="GXXX Device Long Name" FontWeight="Bold" FontSize="12" Foreground="#EEEEEE" MaxWidth="140" Margin="4,0,0,0" Padding="0" />
        <StackPanel Orientation="Horizontal">
            <Grid>
                <Image Source="{Binding DeviceType, ElementName=me, Converter={conv:LogitechNameConverter}}" MaxHeight="36" />
                <Image Source="/Resources/Battery_dark.png" MaxHeight="36" />
                <Image Source="{Binding BatteryIndicator, ElementName=me}" MaxHeight="36" />
                <Image Source="/Resources/Charging.png" MaxHeight="36" Visibility="{Binding IsCharging, ElementName=me}" />
            </Grid>
            <TextBlock Text="{Binding LogitechDevice.BatteryPercentage, ElementName=me, StringFormat={}{0} %}" FontSize="14" Margin="8,0,0,0" Foreground="WhiteSmoke" d:Text="48 %" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </StackPanel>
    </StackPanel>
</UserControl>
